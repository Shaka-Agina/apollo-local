# Copy to .env for `docker compose up` (never commit .env)
# In Portainer: set these under Stack → Environment variables instead.

SLSKD_SLSK_USERNAME=your_soulseek_username
SLSKD_SLSK_PASSWORD=your_soulseek_password

# 16–255 characters; Apollo and slskd must share this value
SLSKD_API_KEY=change_me_to_a_long_random_string

APOLLO_PORT=3000
SLSKD_WEB_PORT=5030
SLSKD_LISTEN_PORT=50300

# Optional — host paths for music (Unraid SMB mounted on the VM).
# Leave unset to use Docker named volumes instead.
# MUSIC_DIR=/mnt/homeos/Media/Music
# INCOMPLETE_DIR=/mnt/homeos/Media/Apollo/incomplete
# SHARED_DIR=/mnt/homeos/Media/Apollo/shared

# =============================================================================
# Local Next.js (non-Docker) — copy these into `.env.local` instead
# =============================================================================
# SLSKD_URL=http://127.0.0.1:5030
# SLSKD_API_KEY=change_me_to_a_long_random_string
# SLSKD_CONFIG_PATH=/opt/apollo/slskd/config/slskd.yml
# Windows example: C:\path\to\apollo-local\slskd\app\slskd.yml
