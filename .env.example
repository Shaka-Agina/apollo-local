# Copy to .env.local (never commit .env.local)

# Where the slskd HTTP API lives
SLSKD_URL=http://127.0.0.1:5030

# Must match web.authentication.api_keys.apollo.key in slskd.yml
SLSKD_API_KEY=change_me_to_a_long_random_string

# Absolute path to the live slskd.yml (Apollo Settings writes here)
# Windows (native):  C:\path\to\apollo-local\slskd\app\slskd.yml
# Linux (Docker):    /opt/apollo/slskd/config/slskd.yml
SLSKD_CONFIG_PATH=/opt/apollo/slskd/config/slskd.yml
